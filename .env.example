# COTA's GTFS-realtime feeds (VehiclePositions/TripUpdates/Alerts) are public
# and unauthenticated — no API key needed.

# Bluesky
BLUESKY_SERVICE=https://bsky.social
BLUESKY_BUS_IDENTIFIER=
BLUESKY_BUS_APP_PASSWORD=

# Throwaway Bluesky account for manually testing post output without publishing
# to a live bot account. Optional — no automated job reads these.
TEST_ACCOUNT_IDENTIFIER=
TEST_ACCOUNT_PASSWORD=

# Mapbox — https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=
