# CTA API keys — request at https://www.transitchicago.com/developers/
CTA_TRAIN_KEY=
CTA_BUS_KEY=

# Metra GTFS-realtime API key — request at https://metra.com/developers
# Passed as the `api_token` query param to gtfspublic.metrarr.com feeds.
METRA_API_KEY=

# Bluesky
BLUESKY_SERVICE=https://bsky.social
BLUESKY_BUS_IDENTIFIER=
BLUESKY_BUS_APP_PASSWORD=
BLUESKY_TRAIN_IDENTIFIER=
BLUESKY_TRAIN_APP_PASSWORD=
# Alerts/disruptions account — used by bin/{bus,train}/alerts.js and bin/train/pulse.js
BLUESKY_ALERTS_IDENTIFIER=
BLUESKY_ALERTS_APP_PASSWORD=
# Metra analytics bot (speedmap/recap) + Metra disruptions account
# (cancellations/delays/alerts) — used by the bin/metra/* jobs.
BLUESKY_METRA_IDENTIFIER=
BLUESKY_METRA_APP_PASSWORD=
BLUESKY_METRA_ALERTS_IDENTIFIER=
BLUESKY_METRA_ALERTS_APP_PASSWORD=

# Mapbox — https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=
