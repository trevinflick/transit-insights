{
  "name": "cta-insights",
  "version": "0.0.1",
  "description": "Bluesky bots that turn CTA train and bus tracker data into Chicago-specific transit visualizations",
  "main": "index.js",
  "dependencies": {
    "@atproto/api": "^0.18.16",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^8.1.0",
    "gtfs-realtime-bindings": "^2.0.0",
    "lodash": "^4.18.1",
    "minimist": "^1.2.3",
    "sharp": "^0.34.5"
  },
  "scripts": {
    "bunching": "node bin/bus/bunching.js",
    "bunching:dry": "node bin/bus/bunching.js --dry-run",
    "gaps": "node bin/bus/gaps.js",
    "gaps:dry": "node bin/bus/gaps.js --dry-run",
    "fetch-gtfs": "node scripts/fetch-gtfs.js",
    "fetch-metra-gtfs": "node scripts/fetch-metra-gtfs.js",
    "observe-metra": "node scripts/observeMetra.js",
    "fetch-signals": "node scripts/fetch-signals.js",
    "speedmap": "node bin/bus/speedmap.js",
    "speedmap:dry": "node bin/bus/speedmap.js --dry-run",
    "recap": "node bin/bus/recap.js",
    "recap:dry": "node bin/bus/recap.js --dry-run",
    "train-snapshot": "node bin/train/snapshot.js",
    "train-snapshot:dry": "node bin/train/snapshot.js --dry-run",
    "train-bunching": "node bin/train/bunching.js",
    "train-bunching:dry": "node bin/train/bunching.js --dry-run",
    "train-gaps": "node bin/train/gaps.js",
    "train-gaps:dry": "node bin/train/gaps.js --dry-run",
    "train-speedmap": "node bin/train/speedmap.js",
    "train-speedmap:dry": "node bin/train/speedmap.js --dry-run",
    "train-recap": "node bin/train/recap.js",
    "train-recap:dry": "node bin/train/recap.js --dry-run",
    "observe-buses": "node scripts/observeBuses.js",
    "ghosts": "node bin/bus/ghosts.js",
    "ghosts:dry": "node bin/bus/ghosts.js --dry-run",
    "train-ghosts": "node bin/train/ghosts.js",
    "train-ghosts:dry": "node bin/train/ghosts.js --dry-run",
    "test": "node --test test/*.test.js test/**/*.test.js",
    "export-web": "node bin/export-web.js",
    "event-tracks:dry": "node bin/export-event-tracks.js --dry-run",
    "smoke": "for f in bin/bus/*.js bin/train/*.js bin/metra/*.js; do node \"$f\" --check || exit 1; done",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "author": "Cailin Pitt <cailinpitt1@gmail.com> (https://cailinpitt.com)",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
